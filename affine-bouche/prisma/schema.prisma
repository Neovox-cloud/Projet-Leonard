generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Catalogue des fromages importé depuis JSON
model CheeseProfile {
  id                      String   @id @default(cuid())
  nom                     String
  categorie               String?
  lait                    String?
  
  // Phase d'affinage
  affinageTempMin         Float?
  affinageTempMax         Float?
  affinageHygroMin        Float?
  affinageHygroMax        Float?
  affinageDureeMin        Int?
  affinageDureeMax        Int?
  
  // Phase de stabilisation
  stabilisationTempMin    Float?
  stabilisationTempMax    Float?
  stabilisationHygroMin   Float?
  stabilisationHygroMax   Float?
  
  // Entretien
  ventilation             String?
  retournement            String?
  notes                   String?
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// Statut simulé de la cave (Mock)
model MockCave {
  id               String   @id @default(cuid())
  currentTemp      Float    // Température actuelle en °C
  currentHumidity  Float    // Humidité actuelle en %
  fanActive        Boolean  @default(false)
  coolerActive     Boolean  @default(false)
  humidifierActive Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}

model ViandeProfile {
  id                         String   @id
  nom                        String
  categorie                  String
  temp_conservation_degC     Float
  temp_maturation_degC       Float
  hygrometrie_pourcent       Float
  temp_apres_maturation_degC Float
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model VinProfile {
  id                            String   @id
  nom                           String
  type                          String
  temp_conservation_degC        Float
  temp_vieillissement_degC      Float
  hygrometrie_pourcent          Float
  temp_service_recommandee_degC Float
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

model TelemetryEntry {
  id            String   @id @default(cuid())
  compartmentId Int
  deviceName    String   // 'default' or Bluetooth name
  temp          Float
  humidity      Float
  timestamp     DateTime @default(now())

  @@index([deviceName, compartmentId, timestamp])
}

// Modèle Utilisateur pour l'authentification
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Mot de passe haché
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
